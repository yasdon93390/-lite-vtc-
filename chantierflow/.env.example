# ====================== CORE ======================
PORT=3000
NODE_ENV=development
PUBLIC_URL=https://your-domain.com

# ====================== POSTGRES ===================
DATABASE_URL=postgres://user:pass@localhost:5432/chantierflow

# ====================== OPENAI =====================
OPENAI_API_KEY=sk-...

# ====================== TWILIO WHATSAPP ============
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ====================== S3 (optionnel, sinon stockage local) ===
S3_ENABLED=false
S3_BUCKET=chantierflow
S3_REGION=eu-west-3
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=https://chantierflow.s3.eu-west-3.amazonaws.com

# ====================== ENTREPRISE PAR DÉFAUT ======
COMPANY_NAME=ChantierFlow Demo
COMPANY_ADDRESS=12 rue de Rivoli, 75001 Paris
COMPANY_SIRET=000 000 000 00000
COMPANY_VAT_RATE=20
